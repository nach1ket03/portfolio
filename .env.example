# Formspree form ID — get yours at https://formspree.io
# Create a form, copy the ID from the endpoint URL (the part after /f/)
# e.g. https://formspree.io/f/abcdefgh  →  NEXT_PUBLIC_FORMSPREE_ID=abcdefgh
# If this variable is not set, the contact form falls back to a mailto: link.
NEXT_PUBLIC_FORMSPREE_ID=
